{
  "name": "llmpack",
  "version": "0.1.0",
  "description": "Auto-detect data shape and format it into the most token-efficient representation for LLM prompts",
  "keywords": ["llm", "tokens", "format", "prompt", "ai", "csv", "yaml", "toon"],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/devanshg03/llmpack.git"
  },
  "bugs": {
    "url": "https://github.com/devanshg03/llmpack/issues"
  },
  "homepage": "https://github.com/devanshg03/llmpack#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node && bun tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build && bun test",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:snapshots": "bun test tests/snapshots",
    "bench": "bun ./benchmarks/token-savings.bench.ts",
    "typecheck": "bun tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5",
    "@dqbd/tiktoken": "^1"
  },
  "peerDependenciesMeta": {
    "@dqbd/tiktoken": {
      "optional": true
    }
  }
}
